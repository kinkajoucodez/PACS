// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums matching the database schema
enum UserRole {
  admin
  radiologist
  provider_manager
  billing_officer
  support
  auditor
}

enum UserStatus {
  active
  inactive
  suspended
  pending_verification
}

enum StudyPriority {
  stat
  urgent
  routine
  follow_up
}

enum StudyStatus {
  received
  queued
  assigned
  in_progress
  reported
  verified
  disputed
  amended
}

enum AssignmentStatus {
  pending
  accepted
  in_progress
  completed
  released
  escalated
  reassigned
}

enum ReportStatus {
  draft
  preliminary
  final
  amended
  cancelled
}

enum SlaStatus {
  on_track
  warning
  breached
}

enum DisputeStatus {
  open
  under_review
  resolved_original_correct
  resolved_amended
  escalated
  closed
}

enum VerificationStatus {
  pending
  under_review
  approved
  rejected
  expired
}

enum NotificationType {
  study_assigned
  stat_alert
  sla_warning
  sla_breach
  dispute_filed
  report_completed
  credential_status
  system_alert
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum BillingStatus {
  pending
  billable
  invoiced
  paid
  waived
}

// Tables
model User {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String     @unique
  passwordHash      String?    @map("password_hash")
  firstName         String     @map("first_name")
  lastName          String     @map("last_name")
  role              UserRole
  status            UserStatus @default(pending_verification)
  phone             String?
  twoFactorEnabled  Boolean    @default(false) @map("two_factor_enabled")
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  radiologistProfile   RadiologistProfile?
  verifiedProfiles     RadiologistProfile[] @relation("VerifiedBy")
  statFlaggedStudies   Study[]              @relation("StatFlaggedBy")
  assignments          StudyAssignment[]    @relation("Radiologist")
  assignedBy           StudyAssignment[]    @relation("AssignedBy")
  reports              Report[]             @relation("RadiologistReports")
  finalizedReports     Report[]             @relation("FinalizedBy")
  disputesFiled        Dispute[]            @relation("FiledBy")
  disputesReviewing    Dispute[]            @relation("AssignedReviewer")
  billingRecords       BillingRecord[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  ratingsGiven         Rating[]             @relation("RatedBy")
  ratingsReceived      Rating[]             @relation("RadiologistRating")

  @@map("users")
}

model RadiologistProfile {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  licenseNumber      String?            @map("license_number")
  licenseExpiry      DateTime?          @map("license_expiry") @db.Date
  specializations    String[]
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verifiedBy         String?            @map("verified_by") @db.Uuid
  verifiedAt         DateTime?          @map("verified_at") @db.Timestamptz
  yearsOfExperience  Int?               @map("years_of_experience")
  averageRating      Decimal            @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalRatings       Int                @default(0) @map("total_ratings")
  documentsUrl       String?            @map("documents_url")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier   User? @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@map("radiologist_profiles")
}

model HealthcareProvider {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  code          String   @unique
  address       String?
  city          String?
  state         String?
  country       String?
  phone         String?
  email         String?
  contactPerson String?  @map("contact_person")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  studies           Study[]
  slaConfigurations SlaConfiguration[]
  billingRecords    BillingRecord[]
  invoices          Invoice[]
  reportTemplates   ReportTemplate[]

  @@map("healthcare_providers")
}

model Study {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orthancStudyId     String        @unique @map("orthanc_study_id")
  studyInstanceUid   String        @unique @map("study_instance_uid")
  patientId          String?       @map("patient_id")
  patientNameHash    String?       @map("patient_name_hash")
  modality           String?
  studyDescription   String?       @map("study_description")
  studyDate          DateTime?     @map("study_date") @db.Date
  referringPhysician String?       @map("referring_physician")
  bodyPart           String?       @map("body_part")
  priority           StudyPriority @default(routine)
  status             StudyStatus   @default(received)
  providerId         String?       @map("provider_id") @db.Uuid
  isAnonymized       Boolean       @default(true) @map("is_anonymized")
  statFlaggedAt      DateTime?     @map("stat_flagged_at") @db.Timestamptz
  statFlaggedBy      String?       @map("stat_flagged_by") @db.Uuid
  receivedAt         DateTime      @default(now()) @map("received_at") @db.Timestamptz
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider         HealthcareProvider? @relation(fields: [providerId], references: [id])
  statFlaggedByUser User?              @relation("StatFlaggedBy", fields: [statFlaggedBy], references: [id])
  assignments      StudyAssignment[]
  reports          Report[]
  slaTracking      SlaTracking?
  billingRecord    BillingRecord?
  disputes         Dispute[]
  ratings          Rating[]

  @@map("studies")
}

model ReportTemplate {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId      String?             @map("provider_id") @db.Uuid
  name            String
  description     String?
  modality        String?
  bodyPart        String?             @map("body_part")
  templateFormat  String              @default("HTML") @map("template_format")
  templateContent String?             @map("template_content")
  language        String              @default("en")
  placeholders    Json?
  isActive        Boolean             @default(true) @map("is_active")
  version         Int                 @default(1)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider HealthcareProvider? @relation(fields: [providerId], references: [id])
  reports  Report[]

  @@map("report_templates")
}

model Report {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId        String       @map("study_id") @db.Uuid
  radiologistId  String       @map("radiologist_id") @db.Uuid
  templateId     String?      @map("template_id") @db.Uuid
  status         ReportStatus @default(draft)
  findings       String?
  impression     String?
  conclusion     String?
  reportBody     String?      @map("report_body")
  version        Int          @default(1)
  parentReportId String?      @map("parent_report_id") @db.Uuid
  isAddendum     Boolean      @default(false) @map("is_addendum")
  finalizedAt    DateTime?    @map("finalized_at") @db.Timestamptz
  finalizedBy    String?      @map("finalized_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  study            Study           @relation(fields: [studyId], references: [id])
  radiologist      User            @relation("RadiologistReports", fields: [radiologistId], references: [id])
  template         ReportTemplate? @relation(fields: [templateId], references: [id])
  parentReport     Report?         @relation("ReportAddenda", fields: [parentReportId], references: [id])
  addenda          Report[]        @relation("ReportAddenda")
  finalizer        User?           @relation("FinalizedBy", fields: [finalizedBy], references: [id])
  disputes         Dispute[]       @relation("ReportDispute")
  originalDisputes Dispute[]       @relation("OriginalReport")
  amendedDisputes  Dispute[]       @relation("AmendedReport")
  ratings          Rating[]

  @@map("reports")
}

model StudyAssignment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId          String           @map("study_id") @db.Uuid
  radiologistId    String           @map("radiologist_id") @db.Uuid
  assignedById     String           @map("assigned_by") @db.Uuid
  assignmentStatus AssignmentStatus @default(pending) @map("assignment_status")
  assignedAt       DateTime         @default(now()) @map("assigned_at") @db.Timestamptz
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz
  completedAt      DateTime?        @map("completed_at") @db.Timestamptz
  releasedAt       DateTime?        @map("released_at") @db.Timestamptz
  releaseReason    String?          @map("release_reason")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  study       Study @relation(fields: [studyId], references: [id])
  radiologist User  @relation("Radiologist", fields: [radiologistId], references: [id])
  assignedBy  User  @relation("AssignedBy", fields: [assignedById], references: [id])

  @@map("study_assignments")
}

model SlaConfiguration {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId              String        @map("provider_id") @db.Uuid
  modality                String?
  priority                StudyPriority
  targetHours             Decimal       @map("target_hours") @db.Decimal(6, 2)
  warningThresholdPercent Int           @default(80) @map("warning_threshold_percent")
  isActive                Boolean       @default(true) @map("is_active")
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider    HealthcareProvider @relation(fields: [providerId], references: [id])
  slaTracking SlaTracking[]

  @@unique([providerId, modality, priority])
  @@map("sla_configurations")
}

model SlaTracking {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId       String    @unique @map("study_id") @db.Uuid
  slaConfigId   String    @map("sla_config_id") @db.Uuid
  deadlineAt    DateTime  @map("deadline_at") @db.Timestamptz
  warningSentAt DateTime? @map("warning_sent_at") @db.Timestamptz
  breachedAt    DateTime? @map("breached_at") @db.Timestamptz
  status        SlaStatus @default(on_track)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  study     Study            @relation(fields: [studyId], references: [id])
  slaConfig SlaConfiguration @relation(fields: [slaConfigId], references: [id])

  @@map("sla_tracking")
}

model Invoice {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber      String        @unique @map("invoice_number")
  providerId         String        @map("provider_id") @db.Uuid
  billingPeriodStart DateTime      @map("billing_period_start") @db.Date
  billingPeriodEnd   DateTime      @map("billing_period_end") @db.Date
  subtotal           Decimal       @db.Decimal(12, 2)
  taxAmount          Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount        Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency           String        @default("USD")
  status             InvoiceStatus @default(draft)
  issuedAt           DateTime?     @map("issued_at") @db.Timestamptz
  dueAt              DateTime?     @map("due_at") @db.Timestamptz
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz
  paymentReference   String?       @map("payment_reference")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider       HealthcareProvider @relation(fields: [providerId], references: [id])
  billingRecords BillingRecord[]
  invoiceItems   InvoiceItem[]

  @@map("invoices")
}

model BillingRecord {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId       String        @unique @map("study_id") @db.Uuid
  providerId    String        @map("provider_id") @db.Uuid
  radiologistId String?       @map("radiologist_id") @db.Uuid
  modality      String?
  priority      StudyPriority?
  baseAmount    Decimal       @map("base_amount") @db.Decimal(10, 2)
  statSurcharge Decimal       @default(0) @map("stat_surcharge") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        BillingStatus @default(pending)
  invoiceId     String?       @map("invoice_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  study        Study               @relation(fields: [studyId], references: [id])
  provider     HealthcareProvider  @relation(fields: [providerId], references: [id])
  radiologist  User?               @relation(fields: [radiologistId], references: [id])
  invoice      Invoice?            @relation(fields: [invoiceId], references: [id])
  invoiceItems InvoiceItem[]

  @@map("billing_records")
}

model InvoiceItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  billingRecordId String?  @map("billing_record_id") @db.Uuid
  description     String
  quantity        Int      @default(1)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  billingRecord BillingRecord? @relation(fields: [billingRecordId], references: [id])

  @@map("invoice_items")
}

model Dispute {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId            String        @map("study_id") @db.Uuid
  reportId           String        @map("report_id") @db.Uuid
  filedById          String        @map("filed_by") @db.Uuid
  assignedReviewerId String?       @map("assigned_reviewer_id") @db.Uuid
  status             DisputeStatus @default(open)
  reason             String?
  resolutionNotes    String?       @map("resolution_notes")
  originalReportId   String?       @map("original_report_id") @db.Uuid
  amendedReportId    String?       @map("amended_report_id") @db.Uuid
  filedAt            DateTime      @default(now()) @map("filed_at") @db.Timestamptz
  resolvedAt         DateTime?     @map("resolved_at") @db.Timestamptz
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  study            Study   @relation(fields: [studyId], references: [id])
  report           Report  @relation("ReportDispute", fields: [reportId], references: [id])
  filedBy          User    @relation("FiledBy", fields: [filedById], references: [id])
  assignedReviewer User?   @relation("AssignedReviewer", fields: [assignedReviewerId], references: [id])
  originalReport   Report? @relation("OriginalReport", fields: [originalReportId], references: [id])
  amendedReport    Report? @relation("AmendedReport", fields: [amendedReportId], references: [id])

  @@map("disputes")
}

model Rating {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studyId          String   @map("study_id") @db.Uuid
  reportId         String   @map("report_id") @db.Uuid
  radiologistId    String   @map("radiologist_id") @db.Uuid
  ratedById        String   @map("rated_by") @db.Uuid
  stars            Int
  feedback         String?
  isDisputeRelated Boolean  @default(false) @map("is_dispute_related")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  study       Study  @relation(fields: [studyId], references: [id])
  report      Report @relation(fields: [reportId], references: [id])
  radiologist User   @relation("RadiologistRating", fields: [radiologistId], references: [id])
  ratedBy     User   @relation("RatedBy", fields: [ratedById], references: [id])

  @@unique([studyId, ratedById])
  @@map("ratings")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Notification {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          NotificationType
  title         String
  message       String?
  isRead        Boolean          @default(false) @map("is_read")
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  readAt        DateTime?        @map("read_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
